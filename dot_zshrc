# ~/.zshrc - Minimal setup for macOS

# payaus native dev — before the interactive guard so non-interactive shells (scripts, agents) get it too
export RUNNING_LOCAL_NATIVE_ENV=true
export DEV_CATCH_EMAIL=true

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

# =================
# Secrets & plugins
# =================

# Load private secrets (not in version control)
[[ -f ~/.secrets ]] && source ~/.secrets

# Load antidote plugin manager
source $(brew --prefix)/opt/antidote/share/antidote/antidote.zsh
antidote load ${ZDOTDIR:-$HOME}/.zsh_plugins.txt

# =================
# Environment
# =================

export EDITOR='nvim'
export VISUAL='nvim'

export PATH="/opt/homebrew/opt/postgresql@17/bin:$PATH"

# =================
# Aliases
# =================

alias vim='nvim'
alias lg='lazygit'

# =================
# Project-specific
# =================

# Suppress macOS alert dialogs when bin/dev processes fail (payaus)
export DISABLE_DEV_NOTIFICATIONS=true
export PROSOPITE_RAISE=true
export DISABLE_ACTIVERECORD_LOGS=true
export DISABLE_SKILL_HOOK=1

# =================
# Tool initialisation
# =================

if command -v starship &> /dev/null; then
  eval "$(starship init zsh)"
fi

if command -v zoxide &> /dev/null; then
  eval "$(zoxide init zsh)"
fi

if command -v mcfly &> /dev/null; then
  eval "$(mcfly init zsh)"
fi

# mise: resolution is via shims only (also prepended in .zshenv for
# non-interactive shells). Deliberately NOT using `mise activate` — it removes
# the shims dir from PATH and prepends version-specific dirs, so child
# processes (git hooks, agents, IDEs) inherit a PATH that only resolves
# correctly for the directory the shell happened to be in. Shims resolve
# per-directory at exec time instead. See https://mise.jdx.dev/dev-tools/shims.html
# This re-prepend must stay LAST: macOS /etc/zprofile (path_helper) and rc-file
# PATH edits above would otherwise put Homebrew's node ahead of the shims.
export PATH="$HOME/.local/share/mise/shims:$PATH"

# See https://git-scm.com/docs/git-config

[user]
	name = {{ .name }}
	email = {{ .email }}

[core]
	pager = delta
	excludesfile = ~/.global_gitignore
	hooksPath = ~/.config/git/hooks

[init]
	defaultBranch = master

[pull]
	rebase = true 			 # Rebase (instead of merge) on pull

[push]
	autoSetupRemote = true   # Automatically set upstream branch on push

[merge]
	conflictstyle = zdiff3
	tool = nvimdiff

[diff]
	algorithm = histogram    # Clearer diffs on moved/edited lines
	colorMoved = plain       # Highlight moved blocks in diffs
	mnemonicPrefix = true    # More intuitive refs in diff output
	tool = nvimdiff

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	dark = true

[commit]
	verbose = true           # Include diff comment in commit message template

[column]
	ui = auto 			     # Output in columns when possible

[branch]
	sort = -committerdate    # Sort branches by most recent commit first

[tag]
	sort = -version:refname  # Sort version numbers as you would expect

[rerere]
	enabled = true           # Record and reuse conflict resolutions
	autoupdate = true        # Apply stored conflict resolutions automatically

# Personal git-town preferences. Repo-specific keys (main-branch, forge-type,
# github-connector) stay per-repo / auto-detected — not set here.
[git-town]
	sync-feature-strategy = merge      # merge, not compress/rebase: never rewrites history, so push-branches=false stays conflict-free
	sync-prototype-strategy = rebase
	sync-perennial-strategy = ff-only
	push-branches = false              # syncs don't push (saves CI); push deliberately with `git town sync --push`
	share-new-branches = no
	ship-strategy = api
	ship-delete-tracking-branch = false
	sync-tags = false
	sync-upstream = true
	auto-sync = true
	detached = false
	push-hook = true
	stash = true
	ignore-uncommitted = false
	interactive = true
	new-branch-type = feature
	unknown-branch-type = feature
	order = asc
	proposal-breadcrumb = stacks
	proposal-breadcrumb-direction = down

[alias]
	# Basic aliases
	co = checkout
	br = branch
	ci = commit
	st = status

	# git-town aliases
	append = town append
	compress = town compress
	contribute = town contribute
	diff-parent = town diff-parent
	hack = town hack
	delete = town delete
	observe = town observe
	park = town park
	prepend = town prepend
	propose = town propose
	repo = town repo
	set-parent = town set-parent
	sync = town sync
	rename = town rename
	continue = town continue
	down = town down
	up = town up

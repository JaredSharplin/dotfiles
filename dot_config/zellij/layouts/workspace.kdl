layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="https://github.com/dj95/zjstatus/releases/latest/download/zjstatus.wasm" {
                color_fg      "#ebdbb2"
                color_bg      "#282828"
                color_red     "#fb4934"
                color_green   "#b8bb26"
                color_yellow  "#fabd2f"
                color_blue    "#83a598"
                color_orange  "#fe8019"

                format_left   "{pipe_status} {tabs}"
                format_center ""
                format_right  "{command_task} {notifications} #[fg=$blue,bold]{session} #[fg=$fg]{datetime}"
                format_space  "#[bg=$bg]"

                border_enabled  "false"

                tab_normal              "#[fg=$fg,bg=$bg] {name} #[fg=#665c54]│"
                tab_active              "#[fg=$bg,bg=$green,bold] {name} #[fg=#665c54,bg=$bg]│"
                tab_normal_fullscreen   "#[fg=$fg,bg=$bg] {name} #[fg=#665c54]│"
                tab_active_fullscreen   "#[fg=$bg,bg=$green,bold] {name} #[fg=#665c54,bg=$bg]│"
                tab_normal_sync         "#[fg=$fg,bg=$bg] {name} #[fg=#665c54]│"
                tab_active_sync         "#[fg=$bg,bg=$green,bold] {name} #[fg=#665c54,bg=$bg]│"

                datetime          "#[fg=$fg] {format} "
                datetime_format   "%a %d %b %H:%M"
                datetime_timezone "Australia/Brisbane"

                command_task_command    "bash -c '$HOME/.config/task/scripts/zjstatus-task-check.sh'"
                command_task_format     "{stdout}"
                command_task_interval   "300"
                command_task_rendermode "dynamic"

                // claude-code-zellij-status (Layer 2)
                pipe_status_format    "{output}"
                pipe_status_rendermode "dynamic"

                notifications_format_unread      "#[fg=$yellow] {message} "
                notifications_format_no_notifications ""
                notifications_show_interval      "10"
            }
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="Main" focus=true {
        pane split_direction="vertical" {
            pane size="40%" command="claude" {
                args "--dangerously-skip-permissions"
            }
            pane stacked=true size="60%" {
                pane command="nvim" start_suspended=true
                pane command="lazygit" start_suspended=true
                pane command="taskwarrior-tui" start_suspended=true
                pane command="gh" start_suspended=true {
                    args "dash"
                }
            }
        }
    }

    tab name="Dotfiles" cwd="~/.local/share/chezmoi" {
        pane command="claude" {
            args "--dangerously-skip-permissions"
        }
    }
}

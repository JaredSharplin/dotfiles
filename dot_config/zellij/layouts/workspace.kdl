layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="https://github.com/dj95/zjstatus/releases/latest/download/zjstatus.wasm" {
                color_fg      "#ebdbb2"
                color_bg      "#282828"
                color_red     "#fb4934"
                color_green   "#b8bb26"
                color_yellow  "#fabd2f"
                color_blue    "#83a598"
                color_orange  "#fe8019"

                format_left   "{tabs}"
                format_center ""
                format_right  "{pipe_status} {notifications} #[fg=$blue,bold]{session} #[fg=$fg]{datetime}"
                format_space  "#[bg=$bg]"

                border_enabled  "false"

                tab_normal   "#[fg=$fg,bg=$bg] {name} "
                tab_active   "#[fg=$bg,bg=$green,bold] {name} "

                datetime          "#[fg=$fg] {format} "
                datetime_format   "%a %d %b %H:%M"
                datetime_timezone "Australia/Brisbane"

                // claude-code-zellij-status (Layer 2)
                pipe_status_format    "{output}"
                pipe_status_rendermode "dynamic"

                notifications_format_unread      "#[fg=$yellow] {message} "
                notifications_format_no_notifications ""
                notifications_show_interval      "10"
            }
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="Terminal" focus=true

    tab name="Main" {
        pane split_direction="vertical" {
            pane command="nvim" size="50%"
            pane stacked=true size="50%" {
                pane command="claude" start_suspended=true
                pane command="lazygit" start_suspended=true
            }
        }
    }

    tab name="Dotfiles" cwd="~/.local/share/chezmoi" {
        pane command="claude"
    }
}

#!/usr/bin/env ruby
# frozen_string_literal: true

# Thin task wrapper — handles tab renaming on start/done/stop.
#
# Usage:
#   t start <id>    Start a task, rename current Zellij tab
#   t done <id>     Complete a task, rename tab back
#   t stop <id>     Stop a task, rename tab back
#   t <anything>    Passthrough to task binary

require "json"
require "open3"

MAX_DESC = 30

def task_description(task_id)
  stdout, = Open3.capture3("task", task_id.to_s, "export")
  data = JSON.parse(stdout).first
  data&.fetch("description", "")
rescue JSON::ParserError
  ""
end

def rename_tab(name)
  return unless ENV["ZELLIJ"]

  system("zellij", "action", "rename-tab", name, out: File::NULL, err: File::NULL)
end

def slot_number
  Dir.pwd[/slot-(\d+)/, 1]
end

case ARGV
in ["start", id, *rest]
  system("task", id, "start", *rest) || exit(1)
  desc = task_description(id)
  desc = "#{desc[0, MAX_DESC]}\u2026" if desc.length > MAX_DESC
  rename_tab("##{id} #{desc}")
in ["done", id, *rest]
  system("task", id, "done", *rest) || exit(1)
  slot_n = slot_number
  rename_tab(slot_n ? "Slot #{slot_n}" : "Done")
in ["stop", id, *rest]
  system("task", id, "stop", *rest) || exit(1)
  slot_n = slot_number
  rename_tab(slot_n ? "Slot #{slot_n}" : "Stopped")
else
  exec("task", *ARGV)
end

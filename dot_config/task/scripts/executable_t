#!/usr/bin/env ruby
# frozen_string_literal: true

# Unified workflow command — single entry point for all task lifecycle operations.
# Thin translator: converts intent to Taskwarrior state changes.
# All side effects (slot assignment, git checkout, tab renaming) live in on-modify.
#
# Usage:
#   t start <id>              Start a task (hook assigns slot)
#   t review [pr] [task_id]   Self-review or peer review
#   t qa [task_id]            Advance to QA stage
#   t done [task_id]          Mark task done
#   t <anything>              Passthrough to task binary
#
# task_id is optional when run from inside a slot worktree.
# When run outside a slot (e.g. from Claude Code), pass task_id explicitly.

require "json"
require "open3"

SLOT_BASE  = File.join(Dir.home, "programming/worktrees")
SLOT_COUNT = 6

def run(*args)
  stdout, stderr, status = Open3.capture3(*args)
  abort "Command failed: #{args.join(' ')}\n#{stderr}" unless status.success?
  stdout
end

def slot_number_from_path(path)
  path&.match(/slot-(\d+)/)&.[](1)
end

def active_task_in_slot(slot_dir)
  stdout, = Open3.capture3("task", "+ACTIVE", "export")
  return nil if stdout.strip.empty?

  JSON.parse(stdout, symbolize_names: true)
    .find { it[:project_dir] == slot_dir }
rescue JSON::ParserError
  nil
end

def task_by_id(task_id)
  stdout, = Open3.capture3("task", task_id.to_s, "export")
  return nil if stdout.strip.empty?

  JSON.parse(stdout, symbolize_names: true).first
rescue JSON::ParserError
  nil
end

def current_slot_dir
  slot_n = slot_number_from_path(Dir.pwd)
  slot_n ? File.join(SLOT_BASE, "slot-#{slot_n}") : nil
end

# Resolve the active task: explicit ID > slot context > error
def resolve_task(task_id_arg, require_slot: false)
  if task_id_arg
    t = task_by_id(task_id_arg)
    abort "Task ##{task_id_arg} not found" unless t
    return t
  end

  slot_dir = current_slot_dir
  abort "Not inside a slot worktree and no task ID given" unless slot_dir

  t = active_task_in_slot(slot_dir)
  abort "No active task in this slot" unless t
  t
end

subcommand = ARGV.first

case subcommand
in "start"
  exec("task", *ARGV)

in "review"
  args = ARGV.drop(1)

  # Parse args: t review [pr_number_or_url] [task_id]
  # Heuristic: PR numbers/URLs contain digits and slashes; task IDs are short integers
  pr_arg      = args.find { it.match?(/\d/) && (it.include?("/") || it.length > 3) } ||
                args.find { it.match?(/\A\d{3,}\z/) }
  task_id_arg = args.find { it != pr_arg && it.match?(/\A\d+\z/) }

  # Resolve PR number
  if pr_arg
    pr_number = pr_arg.split("/").last.gsub(/\D/, "")
    abort "Could not extract PR number from: #{pr_arg}" if pr_number.empty?
  end

  # Fetch PR metadata (needed to determine author)
  if pr_number
    pr_json  = run("gh", "pr", "view", pr_number, "--json", "number,title,author,url,state")
    pr_data  = JSON.parse(pr_json, symbolize_names: true)
    pr_state = pr_data[:state]
    abort "PR ##{pr_number} is #{pr_state} — can only review open PRs" unless pr_state == "OPEN"
    pr_url    = pr_data[:url]
    pr_author = pr_data.dig(:author, :login)
    me        = `gh api user -q '.login'`.strip
  end

  if pr_number && pr_author != me
    # External review: find a free slot, checkout branch, create +review task
    occupied = begin
      stdout, = Open3.capture3("task", "+ACTIVE", "export")
      JSON.parse(stdout.empty? ? "[]" : stdout, symbolize_names: true)
        .filter_map { slot_number_from_path(it[:project_dir] || "") }
    rescue JSON::ParserError
      []
    end

    free_slot = (1..SLOT_COUNT).find { !occupied.include?(it.to_s) }
    abort "No free slots available" unless free_slot

    free_slot_dir = File.join(SLOT_BASE, "slot-#{free_slot}")
    Dir.chdir(free_slot_dir) { run("gh", "pr", "checkout", pr_number) }

    new_task_id = run(
      "task", "add",
      "Review PR ##{pr_number}: #{pr_data[:title]}",
      "+review",
      "project_dir:#{free_slot_dir}",
      "pr_url:#{pr_url}"
    ).scan(/\d+/).first

    abort "Failed to create review task" unless new_task_id
    run("task", new_task_id, "start")
    puts "Started review of PR ##{pr_number} in Slot #{free_slot} (task ##{new_task_id})"
  else
    # Self-review: resolve task, set stage + pr_url
    task = resolve_task(task_id_arg)

    # If no PR number given, read from task's PR: annotation
    unless pr_number
      pr_annotation = Array(task[:annotations])
        .map { it[:description] }
        .find { it.match?(/\APR: /) }
      abort "Task ##{task[:id]} has no PR: annotation and no PR number given" unless pr_annotation

      raw_url   = pr_annotation.sub(/\APR: /, "")
      pr_number = raw_url.split("/").last.gsub(/\D/, "")
      pr_url    = raw_url
    end

    run("task", task[:id].to_s, "modify", "stage:self-review", "pr_url:#{pr_url}")
    puts "Task ##{task[:id]} advanced to self-review — PR ##{pr_number}"
  end

in "qa"
  task = resolve_task(ARGV[1])
  run("task", task[:id].to_s, "modify", "stage:qa")
  puts "Task ##{task[:id]} advanced to qa"

in "done"
  task = resolve_task(ARGV[1])
  run("task", task[:id].to_s, "done")
  puts "Task ##{task[:id]} marked done"

else
  exec("task", *ARGV)
end

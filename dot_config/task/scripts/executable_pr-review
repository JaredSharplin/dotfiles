#!/usr/bin/env bash
# Opens a PR for review in a Zellij slot tab, or advances pipeline status.
#
# Usage:
#   pr-review <number|url>   Start reviewing a PR (self-review or external)
#   pr-review self           Mark active task as self-reviewed
#   pr-review qa             Mark active task ready for peer review
#
# Review modes (pr-review <number>):
# - Self-review (author == me): uses current slot, writes review context, renames tab
# - External review (author != me): finds free slot, checks out branch, switches tab

set -euo pipefail

SLOT_COUNT=6
SLOT_BASE="$HOME/programming/worktrees"
CONTEXT_DIR="$HOME/.local/share/task/context"

usage() {
  echo "Usage: pr-review <number|url|self|qa>" >&2
  exit 1
}

[[ $# -eq 1 ]] || usage

# Pipeline status subcommands
if [[ "$1" == "self" || "$1" == "qa" ]]; then
  subcommand="$1"

  # Find active task for current slot
  slot_task=$(task +ACTIVE export 2>/dev/null \
    | jq -r --arg d "$PWD" '.[] | select(.project_dir == $d) | .id // empty' \
    | head -1)
  [[ -n "$slot_task" ]] || { echo "No active task found for $PWD" >&2; exit 1; }

  # Get PR number from task's PR: annotation
  pr_num=$(task "$slot_task" export 2>/dev/null \
    | jq -r '.[0].annotations // [] | map(select(.description | test("^PR: "))) | last | .description // empty' \
    | sed 's|.*[^0-9]\([0-9]*\)$|\1|')
  [[ -n "$pr_num" ]] || { echo "Task #${slot_task} has no PR: annotation" >&2; exit 1; }

  case "$subcommand" in
    self) task "$slot_task" annotate "Self-reviewed: PR #${pr_num}" ;;
    qa)   task "$slot_task" annotate "Ready for peer review: PR #${pr_num}" ;;
  esac
  exit 0
fi

# Extract PR number from argument (handles both "1234" and full GitHub URLs)
input="$1"
pr_number="${input##*/}"
pr_number="${pr_number//[^0-9]/}"

[[ -n "$pr_number" ]] || { echo "Could not extract PR number from: $input" >&2; exit 1; }

# Must be inside Zellij
[[ -n "${ZELLIJ:-}" ]] || { echo "Not inside a Zellij session" >&2; exit 1; }

# Fetch PR metadata
pr_json=$(gh pr view "$pr_number" --json number,title,author,url,state)
pr_author=$(jq -r '.author.login' <<< "$pr_json")
pr_state=$(jq -r '.state' <<< "$pr_json")

if [[ "$pr_state" != "OPEN" ]]; then
  echo "PR #$pr_number is $pr_state — can only review open PRs" >&2
  exit 1
fi

# Get current GitHub user
me=$(gh api user -q '.login')

mkdir -p "$CONTEXT_DIR"

write_context() {
  local slot_dir="$1"
  local self_review="$2"
  local slot_n="$3"
  jq --arg slot "$slot_dir" --argjson self "$self_review" '{
    pr_number: .number,
    title: .title,
    author: .author.login,
    url: .url,
    is_self_review: $self,
    project_dir: $slot
  }' <<< "$pr_json" > "$CONTEXT_DIR/review-slot-$slot_n.json"
}

setup_slot() {
  local slot_n="$1"
  local slot_dir="$2"
  local self_review="$3"
  (cd "$slot_dir" && gh pr checkout "$pr_number")
  echo "$pr_number" > "$slot_dir/.pr-review"
  write_context "$slot_dir" "$self_review" "$slot_n"
  slot-rename-tab "$slot_n"
}

if [[ "$pr_author" == "$me" ]]; then
  # Self-review mode: use current slot (branch already checked out)
  slot_n=$(echo "$PWD" | sed -n 's/.*slot-\([0-9]*\).*/\1/p')
  [[ -n "$slot_n" ]] || {
    echo "Not inside a slot worktree. Run from ~/programming/worktrees/slot-N" >&2
    exit 1
  }
  slot_dir="$SLOT_BASE/slot-$slot_n"

  setup_slot "$slot_n" "$slot_dir" "true"

  # Auto-add PR: annotation to active task if missing
  slot_task=$(task +ACTIVE export 2>/dev/null \
    | jq -r --arg d "$slot_dir" '.[] | select(.project_dir == $d) | .id // empty' \
    | head -1)
  if [[ -n "$slot_task" ]]; then
    has_pr=$(task "$slot_task" export 2>/dev/null \
      | jq -r '[.[0].annotations // [] | .[] | select(.description | test("^PR: "))] | length')
    if [[ "$has_pr" == "0" ]]; then
      pr_url=$(jq -r '.url' <<< "$pr_json")
      task "$slot_task" annotate "PR: ${pr_url}"
      echo "  Annotated task #${slot_task}: PR: ${pr_url}"
    fi
  fi

  echo "Self-review mode active for Slot $slot_n, PR #$pr_number"
  echo "  Exit this session — the loop will start the walkthrough automatically"
else
  # External review mode: find a free slot and check out the branch

  # Find occupied slots: active tasks with project_dir set
  occupied_slots() {
    task +ACTIVE export 2>/dev/null \
      | jq -r '.[] | .project_dir // empty' \
      | sed -n 's/.*slot-\([0-9]*\).*/\1/p' || true
  }

  # Find slots with existing .pr-review markers
  review_slots() {
    for n in $(seq 1 "$SLOT_COUNT"); do
      [[ -f "$SLOT_BASE/slot-$n/.pr-review" ]] && echo "$n" || true
    done
  }

  # Combine occupied slots into a set, find first free
  find_free_slot() {
    local used
    used=$({ occupied_slots; review_slots; } | sort -u)
    for n in $(seq 1 "$SLOT_COUNT"); do
      if ! echo "$used" | grep -qx "$n"; then
        echo "$n"
        return 0
      fi
    done
    return 1
  }

  slot_n=$(find_free_slot) || { echo "No free slots available" >&2; exit 1; }
  slot_dir="$SLOT_BASE/slot-$slot_n"

  echo "Using Slot $slot_n for PR #$pr_number"

  setup_slot "$slot_n" "$slot_dir" "false"

  # Switch to slot tab
  zellij action go-to-tab-name "Slot $slot_n"

  echo "Ready to review PR #$pr_number in Slot $slot_n"
  echo "  Activate the Claude pane to start the walkthrough and review"
  echo "  Run 'pr-done' when finished"
fi

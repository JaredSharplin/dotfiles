#!/usr/bin/env ruby
# frozen_string_literal: true

# Opens a PR for review in a Zellij slot tab, or advances pipeline status.
#
# Usage:
#   pr-review <number|url>   Start reviewing a PR (self-review or external)
#   pr-review self           Mark active task as self-reviewed
#   pr-review qa             Mark active task ready for peer review
#
# Review modes (pr-review <number>):
# - Self-review (author == me): uses current slot, writes review context, renames tab
# - External review (author != me): finds free slot, checks out branch, switches tab

require 'json'
require 'open3'
require 'fileutils'

SLOT_COUNT  = 6
SLOT_BASE   = File.join(Dir.home, 'programming/worktrees')
CONTEXT_DIR = File.join(Dir.home, '.local/share/task/context')

def usage
  abort 'Usage: pr-review <number|url|self|qa>'
end

def run(*args)
  stdout, stderr, status = Open3.capture3(*args)
  abort "Command failed: #{args.join(' ')}\n#{stderr}" unless status.success?
  stdout
end

# ── Pipeline status subcommands ───────────────────────────────────────────────

def handle_pipeline_subcommand(subcommand)
  active_json, = Open3.capture3('task', '+ACTIVE', 'export')
  tasks = JSON.parse(active_json.empty? ? '[]' : active_json, symbolize_names: true)

  slot_task = tasks.find { it[:project_dir] == Dir.pwd }
  abort "No active task found for #{Dir.pwd}" unless slot_task

  task_id = slot_task[:id].to_s

  annotations = slot_task[:annotations] || []
  pr_annotation = annotations.select { it[:description].match?(/\APR: /) }.last
  abort "Task ##{task_id} has no PR: annotation" unless pr_annotation

  pr_num = pr_annotation[:description].scan(/\d+/).last
  abort "Task ##{task_id} has no PR: annotation" unless pr_num

  case subcommand
  in 'self' then run('task', task_id, 'annotate', "Self-reviewed: PR ##{pr_num}")
  in 'qa'   then run('task', task_id, 'annotate', "Ready for peer review: PR ##{pr_num}")
  end

  exit 0
end

# ── Helpers ───────────────────────────────────────────────────────────────────

def slot_number_from_path(path)
  path.match(/slot-(\d+)/)&.captures&.first
end

def active_task_slot_numbers
  stdout, = Open3.capture3('task', '+ACTIVE', 'export')
  return [] if stdout.strip.empty?

  JSON.parse(stdout, symbolize_names: true)
    .filter_map { slot_number_from_path(it[:project_dir] || '') }
end

def review_marker_slot_numbers
  (1..SLOT_COUNT).select { File.exist?(File.join(SLOT_BASE, "slot-#{it}", '.pr-review')) }
                 .map(&:to_s)
end

def find_free_slot
  occupied = (active_task_slot_numbers + review_marker_slot_numbers).uniq
  (1..SLOT_COUNT).find { !occupied.include?(it.to_s) }
end

def write_context(pr_data, slot_dir, self_review, slot_n)
  context = {
    pr_number:     pr_data[:number],
    title:         pr_data[:title],
    author:        pr_data.dig(:author, :login),
    url:           pr_data[:url],
    is_self_review: self_review,
    project_dir:   slot_dir
  }
  File.write(File.join(CONTEXT_DIR, "review-slot-#{slot_n}.json"), JSON.generate(context))
end

def setup_slot(slot_n, slot_dir, pr_number, pr_data, self_review)
  Dir.chdir(slot_dir) { run('gh', 'pr', 'checkout', pr_number) }
  File.write(File.join(slot_dir, '.pr-review'), pr_number)
  write_context(pr_data, slot_dir, self_review, slot_n)
  run('slot-rename-tab', slot_n.to_s)
end

# ── Entry point ───────────────────────────────────────────────────────────────

usage unless ARGV.length == 1

input = ARGV.first

if %w[self qa].include?(input)
  handle_pipeline_subcommand(input)
end

# Extract PR number from argument (handles both "1234" and full GitHub URLs)
pr_number = input.split('/').last.gsub(/\D/, '')
abort "Could not extract PR number from: #{input}" if pr_number.empty?

# Must be inside Zellij
abort 'Not inside a Zellij session' if ENV.fetch('ZELLIJ', '').empty?

# Fetch PR metadata
pr_json  = run('gh', 'pr', 'view', pr_number, '--json', 'number,title,author,url,state')
pr_data  = JSON.parse(pr_json, symbolize_names: true)
pr_author = pr_data.dig(:author, :login)
pr_state  = pr_data[:state]

abort "PR ##{pr_number} is #{pr_state} — can only review open PRs" unless pr_state == 'OPEN'

# Get current GitHub user
me = `gh api user -q '.login'`.strip

FileUtils.mkdir_p(CONTEXT_DIR)

if pr_author == me
  # Self-review mode: use current slot (branch already checked out)
  slot_n = slot_number_from_path(Dir.pwd)
  abort "Not inside a slot worktree. Run from ~/programming/worktrees/slot-N" unless slot_n

  slot_dir = File.join(SLOT_BASE, "slot-#{slot_n}")

  setup_slot(slot_n, slot_dir, pr_number, pr_data, true)

  # Auto-add PR: annotation to active task if missing
  active_json, = Open3.capture3('task', '+ACTIVE', 'export')
  unless active_json.strip.empty?
    tasks = JSON.parse(active_json, symbolize_names: true)
    slot_task = tasks.find { it[:project_dir] == slot_dir }

    if slot_task
      annotations = slot_task[:annotations] || []
      has_pr = annotations.any? { it[:description].match?(/\APR: /) }
      unless has_pr
        pr_url = pr_data[:url]
        run('task', slot_task[:id].to_s, 'annotate', "PR: #{pr_url}")
        puts "  Annotated task ##{slot_task[:id]}: PR: #{pr_url}"
      end
    end
  end

  puts "Self-review mode active for Slot #{slot_n}, PR ##{pr_number}"
  puts '  Exit this session — the loop will start the walkthrough automatically'
else
  # External review mode: find a free slot and check out the branch
  slot_n = find_free_slot
  abort 'No free slots available' unless slot_n

  slot_dir = File.join(SLOT_BASE, "slot-#{slot_n}")

  puts "Using Slot #{slot_n} for PR ##{pr_number}"

  setup_slot(slot_n, slot_dir, pr_number, pr_data, false)

  # Switch to slot tab
  exec('zellij', 'action', 'go-to-tab-name', "Slot #{slot_n}")
end

#!/usr/bin/env ruby
# frozen_string_literal: true

# Renames a Zellij slot tab based on its current context.
#
# Usage: slot-rename-tab [slot_number]
#
# If slot_number is omitted, detects from $PWD.
# Reads stage from task context to determine tab label:
#   execute:     "Slot N: #42 description"
#   self-review: "Slot N: #42 description [self-review]"
#   qa:          "Slot N: #42 description [qa]"
#   peer-review: "Slot N: Reviewing #1234"
#   idle:        "Slot N"

require "json"

CONTEXT_DIR = File.join(Dir.home, ".local/share/task/context")
SLOT_BASE   = File.join(Dir.home, "programming/worktrees")

exit 0 unless ENV["ZELLIJ"]

slot_n = ARGV[0] || Dir.pwd[/slot-(\d+)/, 1]
exit 0 unless slot_n

slot_dir = "#{SLOT_BASE}/slot-#{slot_n}"

task_file = Dir.glob("#{CONTEXT_DIR}/*.json").find do
  data = JSON.parse(File.read(it), symbolize_names: true) rescue next
  data[:project_dir] == slot_dir
end

tab_name =
  if task_file
    data  = JSON.parse(File.read(task_file), symbolize_names: true)
    id    = data[:id]
    desc  = data[:description].to_s.then { it.length > 20 ? "#{it[0, 20]}\u2026" : it }
    stage = data[:stage].to_s

    case stage
    in "self-review"
      "Slot #{slot_n}: ##{id} #{desc} [self-review]"
    in "qa"
      "Slot #{slot_n}: ##{id} #{desc} [qa]"
    in "peer-review"
      pr_num = data[:pr_url]&.split("/")&.last&.gsub(/\D/, "")
      pr_num ? "Slot #{slot_n}: Reviewing ##{pr_num}" : "Slot #{slot_n}: ##{id} #{desc}"
    else
      "Slot #{slot_n}: ##{id} #{desc}"
    end
  else
    "Slot #{slot_n}"
  end

exec("zellij", "action", "rename-tab", tab_name)

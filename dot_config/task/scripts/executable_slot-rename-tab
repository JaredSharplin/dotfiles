#!/usr/bin/env ruby
# frozen_string_literal: true

# Renames a Zellij slot tab based on its current context.
#
# Usage: slot-rename-tab [slot_number]
#
# If slot_number is omitted, detects from $PWD.
# Checks for review context, then task context, then falls back to "Slot N".

require 'json'

CONTEXT_DIR = File.join(Dir.home, '.local/share/task/context')
SLOT_BASE   = File.join(Dir.home, 'programming/worktrees')

exit 0 unless ENV['ZELLIJ']

slot_n = ARGV[0] || Dir.pwd[/slot-(\d+)/, 1]
exit 0 unless slot_n

slot_dir       = "#{SLOT_BASE}/slot-#{slot_n}"
review_context = "#{CONTEXT_DIR}/review-slot-#{slot_n}.json"

tab_name =
  if File.exist?(review_context)
    data = JSON.parse(File.read(review_context), symbolize_names: true)
    pr_number = data[:pr_number]
    if data[:is_self_review]
      "Slot #{slot_n}: Self-review ##{pr_number}"
    else
      "Slot #{slot_n}: Reviewing ##{pr_number}"
    end
  else
    task_file = Dir.glob("#{CONTEXT_DIR}/*.json").find do
      next if File.basename(it).start_with?('review-')

      data = JSON.parse(File.read(it), symbolize_names: true) rescue next
      data[:project_dir] == slot_dir
    end

    if task_file
      data = JSON.parse(File.read(task_file), symbolize_names: true)
      task_id   = data[:id]
      task_desc = data[:description].to_s
      task_desc = "#{task_desc[0, 20]}\u2026" if task_desc.length > 20
      "Slot #{slot_n}: ##{task_id} #{task_desc}"
    else
      "Slot #{slot_n}"
    end
  end

exec('zellij', 'action', 'rename-tab', tab_name)

#!/usr/bin/env ruby
# frozen_string_literal: true

# zjstatus statusbar: task counts + GitHub PR status.
# Run every 300s by zjstatus command_task in workspace layouts.

require "json"

def task_count(*args) = `task #{args.join(" ")} count 2>/dev/null`.strip.to_i

def gh_pr_count(*args)
  JSON.parse(`gh pr list --author @me #{args.join(" ")} --json number 2>/dev/null`).length
rescue JSON::ParserError
  0
end

def color(hex, text) = "#[fg=#{hex}]#{text}"

active  = task_count("+ACTIVE")
queued  = task_count("+PENDING", "-ACTIVE", "-WAITING")
waiting = task_count("+WAITING")

draft_prs = gh_pr_count("--draft")
stale_prs = gh_pr_count("--label", "stale")

cols = (ENV["COLUMNS"] || `tput cols 2>/dev/null`.strip).to_i
next_desc = if cols >= 160
  json = `task +next +PENDING -ACTIVE export 2>/dev/null`
  Array(JSON.parse(json)).first&.fetch("description", nil) rescue nil
end

focus = []
focus << color("#b8bb26", "#{active} active") if active.positive?
focus << color("#fabd2f", "Next: #{next_desc}") if next_desc
focus << color("#fe8019", "#{draft_prs} draft PRs") if draft_prs.positive?
focus << color("#fb4934", "#{stale_prs} stale PRs") if stale_prs.positive?

counts = []
counts << color("#83a598", "#{queued} queued") if queued.positive?
counts << color("#fe8019", "#{waiting} on hold") if waiting.positive?

parts = [focus.join(" "), counts.join(" ")].reject(&:empty?)
puts parts.join(" #[fg=#ebdbb2]| ")

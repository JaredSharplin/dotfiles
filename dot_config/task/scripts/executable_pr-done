#!/usr/bin/env bash
# Cleans up a PR review slot and returns to Main tab.
#
# Usage: pr-done
#
# Detects the current slot from $PWD, removes the .pr-review marker
# and review context file, renames the tab back to "Slot N", and
# switches to Main.

set -euo pipefail

SLOT_BASE="$HOME/programming/worktrees"
CONTEXT_DIR="$HOME/.local/share/task/context"

# Detect slot number from current directory
slot_n=$(echo "$PWD" | sed -n 's/.*slot-\([0-9]*\).*/\1/p')

[[ -n "$slot_n" ]] || { echo "Not in a slot directory (expected path containing slot-N)" >&2; exit 1; }

slot_dir="$SLOT_BASE/slot-$slot_n"
marker="$slot_dir/.pr-review"
context="$CONTEXT_DIR/review-slot-$slot_n.json"

# Read PR number for feedback message
pr_number=""
[[ -f "$marker" ]] && pr_number=$(cat "$marker")

# Clean up marker and context
[[ -f "$marker" ]] && rm "$marker"
[[ -f "$context" ]] && rm "$context"

# Restore tab name and switch to Main
if [[ -n "${ZELLIJ:-}" ]]; then
  zellij action rename-tab "Slot $slot_n"
  zellij action go-to-tab-name "Main"
fi

if [[ -n "$pr_number" ]]; then
  echo "PR #$pr_number review complete. Slot $slot_n freed."
else
  echo "Slot $slot_n cleaned up."
fi

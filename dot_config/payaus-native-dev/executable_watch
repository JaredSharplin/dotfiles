#!/usr/bin/env ruby
# frozen_string_literal: true

# Webpack wrapper for native local development.
#
# Sources .pumaenv then runs webpack against the project config, writing
# compiled assets to public/assets/webpack/ on disk. puma-dev serves them
# as static files.
#
# Agent note: when running long-form (without --once) via a background
# task, do NOT pipe stdout through `tail`/`head`/`grep` without
# `--line-buffered`. Webpack's stdout is the progress stream — each
# compile ends with a line like "webpack X.Y.Z compiled successfully in
# 42015 ms" which is the reliable grep target for Monitor filters.
#
# Usage:
#   ~/.config/payaus-native-dev/watch                 # watch + recompile forever
#   ~/.config/payaus-native-dev/watch --once          # compile once and exit
#   ~/.config/payaus-native-dev/watch --skip-install  # skip yarn install

require_relative "lib"

once = ARGV.delete("--once")
skip_install = ARGV.delete("--skip-install")

pumaenv = PayausNativeDev.require_pumaenv!
ENV["NODE_ENV"] = "development"

project_root = File.dirname(pumaenv)
webpack_config = File.join(project_root, "config", "webpack", "development.babel.js")
abort "ERROR: webpack config not found at #{webpack_config}" unless File.exist?(webpack_config)

Dir.chdir(project_root)
PayausNativeDev.ensure_yarn_install!(project_root, skip: skip_install)

webpack_args = ["--config", webpack_config]
webpack_args << "--watch" unless once

exec("npx", "webpack", *webpack_args, *ARGV)

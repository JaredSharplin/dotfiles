# Local Native Development Environment
# This file is for running Rails locally (not via bin/tunnel or devbox).
# Copy this file to .env and customize as needed.

export DOCSPRING_TOKEN_ID=""
export DOCSPRING_TOKEN_SECRET=""
export SKIP_LIBUA=true
export SECRET_KEY_BASE=1

export DEV_DATABASE_HOST=localhost
export DEV_DATABASE_PORT=5432
export DEV_DATABASE_NAME=payaus_development
export DEV_DATABASE_USERNAME=payaus_local
export DEV_DATABASE_PASSWORD=""

export DEV_JOBS_DATABASE_HOST=localhost
export DEV_JOBS_DATABASE_PORT=5432
export DEV_JOBS_DATABASE_NAME=payaus_jobsdb_development
export DEV_JOBS_DATABASE_USERNAME=payaus_local
export DEV_JOBS_DATABASE_PASSWORD=""

export MEMCACHE_HOST=localhost
export MEMCACHE_PORT=11211

export RUNNING_LOCAL_NATIVE_ENV=true

# CRITICAL: Skip the vault loader entirely. Without this, the vault loads
# config/variables/staging/ which contains SHARED DEV SERVER credentials
# and OVERWRITES the local database env vars above with remote IPs.
# Forgetting this means bin/rails commands target the shared remote database.
export BOOT_WITHOUT_SECRETS=true

# Rails Environment
export RAILS_ENV=development
export PORT=3000

export PUMA_WORKERS=0

export APP_HOST_URL=payaus.test
export VIRTUAL_HOST=payaus.test
export DEFAULT_HOST=payaus.test

# MinIO S3-compatible storage (local development)
export ACTIVE_STORAGE_AWS_BUCKET=payaus-development
export ACTIVE_STORAGE_AWS_REGION=us-east-1
export ACTIVE_STORAGE_ENDPOINT=http://localhost:9000
export FORCE_ACTIVE_STORAGE_PATH_STYLE=true
export RAILS_AWS_USER_ACCESS_KEY=minioadmin
export RAILS_AWS_USER_SECRET_KEY=minioadmin
# Paperclip (legacy) uses different env vars
export AWS_BUCKET=payaus-development
export AWS_PAPERCLIP_HOST_NAME=localhost:9000
export AWS_PAPERCLIP_REGION=ap-southeast-2

# Used when booting up the worker
export QUEUE=payaus.test

export DOCSPRING_TOKEN_ID=local_dev_token_id
export DOCSPRING_TOKEN_SECRET=local_dev_token_secret

export GOOGLE_MAPS_API_KEY=local_dev_key
export MAPBOX_API_KEY=local_dev_key

export METABASE_SECRET=fake-metabase-secret
export ANTHROPIC_API_KEY=local_dev_key

# ActiveRecord Encryption (local dev keys)
export ENCRYPTION_PRIMARY_KEY=local_dev_primary_key_32_chars_xx
export ENCRYPTION_DETERMINISTIC_KEY=local_dev_deterministic_key_32xx
export ENCRYPTION_KEY_DERIVATION_SALT=local_dev_salt_for_key_derivation
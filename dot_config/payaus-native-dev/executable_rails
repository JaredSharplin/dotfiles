#!/usr/bin/env ruby
# frozen_string_literal: true

# Safe Rails wrapper for native local development.
#
# Sources .pumaenv (which sets BOOT_WITHOUT_SECRETS=true) before delegating
# to bin/rails. Without this, the vault loader overwrites local env vars
# with shared remote dev server credentials.
#
# Usage:
#   ~/.config/payaus-native-dev/rails db:migrate
#   ~/.config/payaus-native-dev/rails db:reset
#   ~/.config/payaus-native-dev/rails console

require_relative "lib"

def verify_safety!
  unless ENV["BOOT_WITHOUT_SECRETS"] == "true"
    abort <<~ERROR
      SAFETY ERROR: BOOT_WITHOUT_SECRETS is not set to 'true'.

      Without this, bin/rails will load vault credentials and connect
      to the SHARED REMOTE DEV DATABASE. This wrapper refuses to proceed.

      Check your .pumaenv file has: export BOOT_WITHOUT_SECRETS=true
    ERROR
  end

  unless ENV["DEV_DATABASE_HOST"] == "localhost"
    abort <<~ERROR
      SAFETY ERROR: DEV_DATABASE_HOST is '#{ENV["DEV_DATABASE_HOST"]}', not 'localhost'.

      This wrapper only runs Rails against the local database.
      Check your .pumaenv file has: export DEV_DATABASE_HOST=localhost
    ERROR
  end
end

pumaenv = PayausNativeDev.require_pumaenv!
verify_safety!

# Safe to bypass Rails' protected environment check — we've already
# verified DEV_DATABASE_HOST=localhost and BOOT_WITHOUT_SECRETS=true.
ENV["DISABLE_DATABASE_ENVIRONMENT_CHECK"] = "1"

# Unset vars from shell env that conflict with local Rails commands.
# DISABLE_ACTIVERECORD_LOGS is set for remote dev but blocks migrations locally.
ENV.delete("DISABLE_ACTIVERECORD_LOGS")

bin_rails = File.join(File.dirname(pumaenv), "bin", "rails")
abort "ERROR: bin/rails not found at #{bin_rails}" unless File.exist?(bin_rails)

exec(bin_rails, *ARGV)

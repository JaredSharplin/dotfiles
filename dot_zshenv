# Shims first (login shells re-prepend in .zprofile); append system dirs so shells that inherit a
# stripped PATH still find git/wc/tr. typeset -U dedupes, keeping shims ahead of system ruby.
export PATH="$HOME/.local/share/mise/shims:$PATH:/opt/homebrew/bin:/opt/homebrew/sbin:/usr/bin:/bin:/usr/sbin:/sbin"
typeset -U path PATH

[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

# payaus native dev. In .zshenv (not .zshrc) so non-interactive shells — scripts, git hooks, agents —
# see it, not just interactive terminals. config/boot.rb loads .env.local when set (skipped in tests);
# DEV_CATCH_EMAIL routes dev mail to the local mailpit catcher.
export RUNNING_LOCAL_NATIVE_ENV=true
export DEV_CATCH_EMAIL=true

#!/usr/bin/env ruby
# frozen_string_literal: true

# qa-up — bring up (or tear down) a remote-devbox QA session for a payaus worktree.
#
# Creates a detached zellij session `qa-<worktree>` with four tabs:
#   tunnel  — bin/tunnel <worktree>
#   server  — bin/dev server   (waits for the tunnel's initial sync)
#   worker  — bin/dev worker   (waits for the server to respond)
#   webpack — bin/dev webpack  (waits for the server to respond)
#
# All devbox logic stays in bin/tunnel and bin/dev; this script only
# orchestrates zellij and polls files/URLs for readiness.

require 'English'
require 'fileutils'
require 'json'
require 'open3'
require 'optparse'

PAYAUS = File.expand_path('~/programming/payaus')
CACHE = File.expand_path('~/.cache/qa-up')
STATE_FILE = File.join(CACHE, 'state.json')
LAYOUT_FILE = File.join(CACHE, 'layout.kdl')
SESSION_PREFIX = 'qa-'
# Single-region developer; stated once so the pgrep pattern, ssh config, profile, and
# app domain can't drift apart. Make it env-derived if this ever goes multi-region.
REGION = 'apac'
DEVELOPER = 'jaredsharplin'
ENTANGLER_PGREP = "entangler.*payaus_dev_config_#{REGION}".freeze
SSH_CONFIG = File.expand_path("~/.ssh/payaus_dev_config_#{REGION}")
PROFILE = "tt-dev-#{REGION}".freeze
APP_URL = "https://#{DEVELOPER}.dev.#{REGION}.adnat.co".freeze
ROLES = %w[tunnel server worker webpack].freeze
# The app containers bin/dev server/worker/webpack start on the box. They outlive
# their ssh ttys, so teardown and switching must stop them explicitly.
REMOTE_APP_CONTAINERS = %w[rails payaus-dev-job-work webpack].freeze

SYNC_TIMEOUT = 900
# Remote bundle/yarn + app-image pull + boot + first HTTP response.
SERVER_TIMEOUT = 1800
BRINGUP_TIMEOUT = SYNC_TIMEOUT + SERVER_TIMEOUT

# zellij derives its IPC socket path from $TMPDIR. The macOS default is long, and a
# background Claude task's $TMPDIR is longer still — either can exceed the ~103-byte
# AF_UNIX limit. Pin a short one so bring-up, teardown, and attach share one socket path.
ENV['TMPDIR'] = '/tmp'
# bin/tunnel prompts interactively for a developer name when neither .env nor $DEV_NAME
# has one; in a detached pane that read blocks forever. Supply it so the pane never stalls.
ENV['DEV_NAME'] = DEVELOPER
# Flush milestone output promptly even when stdout is a pipe (e.g. the /qa skill).
$stdout.sync = true

def run(*args, allow_failure: false)
  stdout, stderr, status = Open3.capture3(*args)
  raise "#{args.join(' ')} failed: #{stderr.strip}" unless status.success? || allow_failure

  stdout.strip
end

def log_path(role) = File.join(CACHE, "#{role}.log")
def exit_path(role) = File.join(CACHE, "#{role}.exit")

# state.json is written once before any poller starts, so memoizing is safe and
# avoids re-parsing it every poll tick across the foreground and pane processes.
def state = @state ||= JSON.parse(File.read(STATE_FILE), symbolize_names: true)

def worktrees
  run('git', '-C', PAYAUS, 'worktree', 'list', '--porcelain')
    .split("\n\n")
    .filter_map { it[/^worktree (.+)$/, 1] }
end

def resolve_worktree(arg)
  return pick_worktree_by_name(arg) if arg

  toplevel = run('git', 'rev-parse', '--show-toplevel', allow_failure: true)
  return toplevel if worktrees.include?(toplevel)

  pick_worktree_with_fzf
end

def pick_worktree_by_name(name)
  worktrees.find { File.basename(it) == name } ||
    abort("No worktree named '#{name}'. Run 'git worktree list' to see available worktrees.")
end

def pick_worktree_with_fzf
  abort 'Not inside a payaus worktree, and no TTY for the fzf picker. Pass a worktree name.' unless $stdout.tty?

  choices = worktrees.map { File.basename(it) }.join("\n")
  choice, _, status = Open3.capture3('fzf', '--prompt', 'QA worktree> ', stdin_data: choices)
  abort 'No worktree selected.' unless status.success?

  pick_worktree_by_name(choice.strip)
end

# Includes sessions zellij keeps listed as resurrectable after a kill.
def qa_sessions
  stdout, _, status = Open3.capture3('zellij', 'list-sessions', '--no-formatting')
  return [] unless status.success?

  stdout.split("\n").filter_map do |line|
    name = line.split.first
    { name:, exited: line.include?('EXITED') } if name&.start_with?(SESSION_PREFIX)
  end
end

def remove_session(name)
  run('zellij', 'kill-session', name, allow_failure: true)
  run('zellij', 'delete-session', '--force', name, allow_failure: true)
end

def stop_remote_containers
  _, _, status = Open3.capture3('ssh', '-F', SSH_CONFIG, '-o', 'ConnectTimeout=5', 'devbox',
                                "docker rm -f #{REMOTE_APP_CONTAINERS.join(' ')}")
  if status.success?
    puts 'stopped remote app containers'
  else
    puts 'could not reach devbox to stop app containers (the next bin/dev run replaces them)'
  end
end

def kill_tunnel!
  pids = `pgrep -f "#{ENTANGLER_PGREP}"`.split.map(&:to_i)
  return if pids.empty?

  signal_process_groups('TERM', pids)
  sleep 2
  survivors = `pgrep -f "#{ENTANGLER_PGREP}"`.split.map(&:to_i)
  signal_process_groups('KILL', survivors)
end

def signal_process_groups(signal, pids)
  pids
    .filter_map { `ps -o pgid= -p #{it}`.strip.to_i.nonzero? }
    .uniq
    .each do |pgid|
      Process.kill("-#{signal}", pgid)
    rescue Errno::ESRCH
      nil
    end
end

def handle_existing_sessions(session)
  existing = qa_sessions
  return if existing.empty?

  target = existing.find { it[:name] == session }
  if target && !target[:exited] && !previous_run_failed?
    puts "#{session} is already running. Attach with: qa-up attach #{session.delete_prefix(SESSION_PREFIX)}"
    exit 0
  end

  existing.each { announce_removal(it, session) }
  teardown(existing)
end

def announce_removal(existing, session)
  if existing[:name] == session
    puts 'relaunching (previous run was not healthy)'
  else
    puts "switched from #{existing[:name].delete_prefix(SESSION_PREFIX)}"
  end
end

# The launch path kills the tunnel unconditionally afterwards, and --down kills it
# first, so teardown itself only removes sessions and stops their remote containers.
def teardown(sessions)
  sessions.each { remove_session(it[:name]) }
  stop_remote_containers
end

# Pane wrappers only write an .exit file when their command exits on its own;
# a clean teardown kills them first, so a leftover .exit marks a failed run.
def previous_run_failed?
  ROLES.any? { File.exist?(exit_path(it)) }
end

def prepare_state(worktree_dir)
  FileUtils.mkdir_p(CACHE)
  ROLES.each do |role|
    File.write(log_path(role), '')
    FileUtils.rm_f(exit_path(role))
  end

  File.write(STATE_FILE, JSON.pretty_generate(worktree: File.basename(worktree_dir)))
end

def write_layout
  qa_up = File.expand_path($PROGRAM_NAME)
  tabs = ROLES.map do |role|
    <<~KDL
      tab name="#{role}" cwd="#{PAYAUS}" {
          pane command="#{qa_up}" {
              args "run" "#{role}"
          }
      }
    KDL
  end

  File.write(LAYOUT_FILE, "layout {\n#{tabs.join.gsub(/^/, '    ')}}\n")
end

def launch_session(session)
  run('zellij', 'attach', '--create-background', session)
  run('zellij', '--session', session, '--layout', LAYOUT_FILE)
end

# --- readiness signals (shared by the foreground monitor and the pane gates) ---

# The pane tees each command's output to <role>.log, truncated per run, so a
# marker is this run's. Memoize once seen — the file only grows while we wait.
def log_reached?(role, marker)
  @log_reached ||= {}
  @log_reached["#{role}/#{marker}"] ||=
    File.exist?(log_path(role)) && File.read(log_path(role)).include?(marker)
end

# entangler mirrors "INFO: Ready!" to stdout when its initial sync reaches steady state.
def sync_ready? = log_reached?('tunnel', 'INFO: Ready!')

def http_ready?(url)
  code, = Open3.capture3('curl', '-so', File::NULL, '-w', '%{http_code}', '--max-time', '5', url)
  code.match?(/^[23]/)
end

def wait_for(label, timeout:, failed_if_exited: [], hint: nil, hint_after: 60)
  started = Time.now
  hint_at = hint ? started + hint_after : nil
  until yield
    fail_if_pane_exited(failed_if_exited)
    elapsed = Time.now - started
    abort "Timed out after #{timeout}s waiting for #{label}." if elapsed > timeout
    if hint_at && Time.now > hint_at
      puts "still waiting for #{label} — #{hint}"
      hint_at = nil
    end
    sleep 2
  end
end

def fail_if_pane_exited(roles)
  role = roles.find { File.exist?(exit_path(it)) }
  abort_with_log_tail(role) if role
end

def abort_with_log_tail(role)
  tail = File.read(log_path(role)).split("\n").last(20).join("\n")
  abort "#{role} exited before QA came up. Last output:\n#{tail}"
end

# --- pane wrappers (invoked by the zellij layout as `qa-up run <role>`) ---

def run_role(role)
  Dir.chdir(PAYAUS)
  command =
    case role
    when 'tunnel'
      "bin/tunnel #{state[:worktree]}"
    when 'server'
      gate(role, 'tunnel sync', timeout: SYNC_TIMEOUT) { sync_ready? }
      'bin/dev server'
    when 'worker', 'webpack'
      # Wait for the server to actually serve HTTP, not just finish its deps step:
      # "Running server at" prints before the server's docker compose run pulls the
      # app image, and concurrent pulls of a missing image corrupt containerd's ingest.
      gate(role, 'server to respond', timeout: BRINGUP_TIMEOUT) do
        http_ready?(APP_URL)
      end
      "bin/dev #{role}"
    else
      abort "Unknown role '#{role}'"
    end

  system('bash', '-o', 'pipefail', '-c', "#{command} 2>&1 | tee #{log_path(role)}")
  status = $CHILD_STATUS.exitstatus
  File.write(exit_path(role), status.to_s)
  exit status
end

def gate(role, label, timeout:)
  started = Time.now
  next_heartbeat = 0
  until yield
    elapsed = (Time.now - started).to_i
    if elapsed > timeout
      File.write(exit_path(role), '1')
      abort "#{role}: timed out after #{timeout}s waiting for #{label}"
    end
    if elapsed >= next_heartbeat
      puts "#{role}: waiting for #{label}… (#{elapsed}s)"
      next_heartbeat = elapsed + 15
    end
    sleep 3
  end
end

# --- teardown ---

def down!
  kill_tunnel!
  sessions = qa_sessions
  if sessions.empty?
    puts 'No qa- session running.'
    return
  end

  teardown(sessions)
  puts "killed #{sessions.map { it[:name] }.join(', ')}"
end

# bin/tunnel runs `aws sso login` when the token is expired — interactive, so it would
# block the detached tunnel pane. Preflight the same check and fail fast with the fix.
def ensure_aws_sso!
  return if system('aws', 'sts', 'get-caller-identity', '--profile', PROFILE,
                   out: File::NULL, err: File::NULL)

  abort "AWS SSO for profile #{PROFILE} has expired. Run:\n  aws sso login --profile #{PROFILE}\n" \
        'then re-run qa-up.'
end

def status!
  sessions = qa_sessions
  puts sessions.empty? ? 'No qa- session.' : sessions.map { "session #{it[:name]}#{' (EXITED)' if it[:exited]}" }
  ROLES.each do |role|
    exited = File.exist?(exit_path(role)) ? " [exited #{File.read(exit_path(role)).strip}]" : ''
    log = log_path(role)
    tail = File.exist?(log) && !File.empty?(log) ? File.readlines(log).last(12).join.rstrip : '(no output yet)'
    puts "\n── #{role}#{exited} ──\n#{tail}"
  end
end

# --- main ---

if ARGV.first == 'run'
  run_role(ARGV.fetch(1) { abort 'Usage: qa-up run <role>' })
  exit
end

if ARGV.first == 'attach'
  worktree = File.basename(ARGV[1] || resolve_worktree(nil))
  exec('zellij', 'attach', "#{SESSION_PREFIX}#{worktree}")
end

if ARGV.first == 'status'
  status!
  exit
end

options = { attach: $stdout.tty? }
OptionParser.new do |o|
  o.banner = 'Usage: qa-up [worktree] [--down | attach [worktree] | status] [--no-attach]'
  o.on('--down', 'Tear down the QA session and tunnel') { options[:down] = true }
  o.on('--no-attach', 'Do not attach to the zellij session when ready') { options[:attach] = false }
  o.on('-h', '--help') do
    puts o
    exit
  end
end.parse!

if options[:down]
  down!
  exit
end

worktree_dir = resolve_worktree(ARGV.first)
worktree = File.basename(worktree_dir)
session = "#{SESSION_PREFIX}#{worktree}"

ensure_aws_sso!
handle_existing_sessions(session)
kill_tunnel!
prepare_state(worktree_dir)
write_layout
launch_session(session)
puts "Launched #{session} (tabs: #{ROLES.join(', ')} + scratch shell)"

# The tunnel connects and does its initial sync in seconds; silence here means trouble.
wait_for('tunnel sync', timeout: SYNC_TIMEOUT, failed_if_exited: %w[tunnel], hint_after: 30,
                        hint: 'this should be quick — run `qa-up status`; if the dev box is down, `bin/dev start`') do
  sync_ready?
end
puts 'Tunnel synced — now booting the server (remote deps + boot take a few minutes; quiet is expected).'
wait_for('server to respond', timeout: SERVER_TIMEOUT, failed_if_exited: %w[tunnel server]) { http_ready?(APP_URL) }

branch = run('git', '-C', worktree_dir, 'rev-parse', '--abbrev-ref', 'HEAD')
puts
puts "Worktree: #{worktree} (#{branch})"
puts "App:      #{APP_URL}"
puts "Session:  #{session} (qa-up attach #{worktree})"
puts 'Teardown: qa-up --down'
puts '(webpack may still be compiling — check the webpack tab if assets 404)'
puts
puts "QA_READY url=#{APP_URL} session=#{session}"

exec('zellij', 'attach', session) if options[:attach] && ENV['ZELLIJ'].nil?
